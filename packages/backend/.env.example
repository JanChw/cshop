# ===== 复制本文件为 .env.local 并填入真实值 =====
# .env.local 不被 git 追踪,可放心放置敏感凭据

# --- 服务 ---
PORT=3001
HOSTNAME=0.0.0.0
NODE_ENV=development
DATA_DIR=

# --- 数据库 ---
DB_PATH=

# --- 文件存储 ---
UPLOAD_DIR=
STICKER_DIR=
BACKUP_DIR=
DESIGN_DIR=

# --- 跨域 ---
# 生产环境必须显式列出允许的源,逗号分隔,禁止留 *
CORS_ORIGINS=http://localhost:4321

# --- 认证 ---
# 生产环境必须设置,开发环境留空会打印启动警告
JWT_SECRET=
# 前端地址,用于邮箱激活链接等
APP_URL=http://localhost:4321

# --- 上传限制 ---
UPLOAD_MAX_BYTES=10485760
STICKER_MAX_BYTES=2097152

# --- 地理库 ---
GEO_DB_PATH=

# --- 邮件(SMTP) ---
# 真实 SMTP 凭据,请勿提交到仓库
RECEIVE_EMAIL=imap.qq.com
RECEIVE_PORT=993
SEND_EMAIL=smtp.qq.com
SEND_PORT=465
EMAIL=
EMAIL_AUTH_PASSWORD=

# --- 限流(测试用) ---
RATE_LIMIT_DISABLED=0
