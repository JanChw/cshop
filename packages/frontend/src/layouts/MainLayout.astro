---
import MobileNavBar from '../components/layout/MobileNavBar.tsx'
import TabletNavBar from '../components/layout/TabletNavBar.tsx'
import ThemeInitializer from '../components/layout/ThemeInitializer.tsx'

interface Props {
  title: string
  hideNav?: boolean
}

const { title, hideNav = false } = Astro.props
---

<!doctype html>
<html lang="zh-CN" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <ThemeInitializer client:only="solid-js" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <title>{title} - ByChooow</title>
  </head>
  <body class="bg-background text-on-surface antialiased overflow-x-hidden">
    {!hideNav && (
      <>
        <TabletNavBar client:load />
        <MobileNavBar client:load />
      </>
    )}
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .material-symbols-outlined {
    font-family: 'Material Symbols Outlined';
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    vertical-align: middle;
  }
</style>
