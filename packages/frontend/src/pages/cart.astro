---

<MainLayout title="购物车">
<!-- TopAppBar -->
<header class="bg-surface-container-lowest fixed top-0 w-full z-50 border-b border-outline-variant">
<div class="flex justify-between items-center px-container-margin h-12 w-full">
<div class="flex items-center gap-4">
<button onclick="history.back()" class="hover:opacity-80 transition-opacity active:scale-95 transition-transform duration-150">
<span class="material-symbols-outlined text-primary">arrow_back</span>
</button>
<h1 class="text-title-md font-bold text-on-surface">购物车</h1>
</div>
<div class="flex items-center gap-2">
<span class="text-label-md text-on-surface-variant" id="cart-count">共 {cartItems.reduce((s, i) => s + 1, 0)} 件商品</span>
</div>
</div>
</header>

<CartContent items={cartItems} client:load />

<!-- BottomNavBar (Mobile Only) -->
<nav class="md:hidden fixed bottom-0 left-0 w-full flex justify-around items-center px-4 pb-4 pt-2 bg-surface-container-lowest border-t border-outline-variant z-50">
<a class="flex flex-col items-center justify-center text-on-surface-variant px-4 py-1 hover:bg-surface-container-low rounded-lg transition-all" href="/"><span class="material-symbols-outlined">home</span><span class="text-[10px] font-bold">首页</span></a>
<a class="flex flex-col items-center justify-center text-on-surface-variant px-4 py-1 hover:bg-surface-container-low rounded-lg transition-all" href="/design"><span class="material-symbols-outlined">brush</span><span class="text-[10px] font-bold">设计</span></a>
<a class="flex flex-col items-center justify-center bg-primary text-on-primary rounded-lg px-4 py-1 scale-90 transition-transform duration-200" href="/cart"><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">shopping_cart</span><span class="text-[10px] font-bold">购物车</span></a>
<a class="flex flex-col items-center justify-center text-on-surface-variant px-4 py-1 hover:bg-surface-container-low rounded-lg transition-all" href="/shop"><span class="material-symbols-outlined">storefront</span><span class="text-[10px] font-bold">商店</span></a>
<a class="flex flex-col items-center justify-center text-on-surface-variant px-4 py-1 hover:bg-surface-container-low rounded-lg transition-all" href="/person"><span class="material-symbols-outlined">person</span><span class="text-[10px] font-bold">个人中心</span></a>
</nav>
<style>body { min-height: max(884px, 100dvh); }</style>
</MainLayout>
