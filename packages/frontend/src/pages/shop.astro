---
import MainLayout from '../layouts/MainLayout.astro'
---

<MainLayout title="商店">
<!-- TopAppBar -->
<header class="bg-surface border-b border-outline-variant sticky top-0 z-50">
<div class="flex justify-between items-center px-container-margin h-12 w-full max-w-7xl mx-auto">
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-primary hover:opacity-80 transition-opacity active:scale-95 duration-150">menu</button>
<span class="text-title-md font-bold text-primary">ByChooow</span>
</div>
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-on-surface-variant hover:opacity-80 transition-opacity">search</button>
<div class="w-8 h-8 rounded-full bg-secondary-container overflow-hidden border border-outline-variant">
<img alt="User Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuACO1FDt1_uQh0Ln4IggOJsy5ok06DnWLxkv-5QqU_NHrM2pT6ekUGzJiEMa_8Bc-a5x8UExX9Pa1IKJ0AdUWXxcdUk3JcFUf2AJ4fH81hhmfB-dcUNFhgjYOPUN5w4Kpn_r8xmCVsdhG5a5A_cvCMl8NQh0N6OY7KYtMd_dTgKldopmOGbd0Pv1qUGdIzpci5rxf9-qsILxfX_27XLvCczAnNF4Pc6I4nEeZZn1ds9Y8AjTxaS2MrfrRBe1T4YPK8LFSkGbZEuDcU"/>
</div>
</div>
</div>
</header>

<!-- Main Content Canvas -->
<main class="max-w-7xl mx-auto pb-32">
<!-- Search & Filter Header -->
<section class="px-container-margin pt-stack-lg pb-stack-md">
<div class="flex flex-col gap-stack-md">
<h1 class="text-headline-lg-mobile md:text-headline-lg text-on-surface">探索精品</h1>
<!-- Category Chips -->
<div class="flex overflow-x-auto no-scrollbar gap-stack-sm pb-2">
<button class="flex-shrink-0 bg-primary text-on-primary px-4 py-2 rounded-lg font-label-md text-label-md transition-transform active:scale-95">全部</button>
<button class="flex-shrink-0 bg-surface-container-high text-on-surface-variant px-4 py-2 rounded-lg font-label-md text-label-md hover:bg-surface-variant transition-colors">基础系列 (Basics)</button>
<button class="flex-shrink-0 bg-surface-container-high text-on-surface-variant px-4 py-2 rounded-lg font-label-md text-label-md hover:bg-surface-variant transition-colors">核心系列 (Essentials)</button>
<button class="flex-shrink-0 bg-surface-container-high text-on-surface-variant px-4 py-2 rounded-lg font-label-md text-label-md hover:bg-surface-variant transition-colors">设计师款 (Designer)</button>
<button class="flex-shrink-0 bg-surface-container-high text-on-surface-variant px-4 py-2 rounded-lg font-label-md text-label-md hover:bg-surface-variant transition-colors">定制款 (Custom)</button>
</div>
</div>
</section>

<!-- Advanced Filter Bar -->
<section class="px-container-margin py-stack-md flex items-center justify-between border-y border-outline-variant/30 sticky top-12 bg-background z-40">
<div class="flex gap-stack-md overflow-x-auto no-scrollbar py-1">
<div class="flex items-center gap-1 border border-primary text-primary rounded-lg px-3 py-1.5 whitespace-nowrap bg-surface">
<span class="text-label-md">面料: 棉质</span>
<span class="material-symbols-outlined text-[16px]">keyboard_arrow_down</span>
</div>
<div class="flex items-center gap-1 border border-outline rounded-lg px-3 py-1.5 whitespace-nowrap bg-surface">
<span class="text-label-md">版型: 宽松</span>
<span class="material-symbols-outlined text-[16px]">keyboard_arrow_down</span>
</div>
<div class="flex items-center gap-1 border border-outline rounded-lg px-3 py-1.5 whitespace-nowrap bg-surface">
<span class="text-label-md">价格: ¥200+</span>
<span class="material-symbols-outlined text-[16px]">keyboard_arrow_down</span>
</div>
</div>
<button class="ml-4 flex items-center gap-2 text-primary font-label-md text-label-md">
<span class="material-symbols-outlined">tune</span>
<span class="hidden md:inline">筛选</span>
</button>
</section>

<!-- Product Grid -->
<section class="px-container-margin py-stack-lg grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-gutter">
<!-- Product Card 1 -->
<div class="group cursor-pointer" onclick="this.style.transform='scale(0.98)';setTimeout(()=>this.style.transform='scale(1)',100)">
