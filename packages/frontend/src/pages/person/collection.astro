---
import MainLayout from '../../layouts/MainLayout.astro'
---

<MainLayout title="收藏与草稿">
<header class="bg-surface border-b border-outline-variant flex justify-between items-center px-6 h-16 w-full sticky top-0 z-40">
<button class="material-symbols-outlined text-primary hover:bg-surface-container-high transition-colors p-2 rounded-full">arrow_back</button>
<h1 class="font-headline text-2xl font-bold text-primary">收藏与草稿</h1>
<button class="material-symbols-outlined text-primary hover:bg-surface-container-high transition-colors p-2 rounded-full">search</button>
</header>
<main class="max-w-4xl mx-auto px-6 pt-8 pb-24">
<div class="flex items-center gap-8 mb-8 border-b border-outline-variant/60 overflow-x-auto whitespace-nowrap">
<button class="pb-3 text-lg font-medium transition-all text-primary border-b-2 border-primary" id="tab-favorites" onclick="switchTab('favorites')">我的收藏</button>
<button class="pb-3 text-lg font-medium transition-all text-on-surface-variant/60 hover:text-on-surface-variant" id="tab-drafts" onclick="switchTab('drafts')">设计草稿</button>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8 transition-opacity duration-300" id="content-favorites">
<div class="bg-surface-container-low rounded-xl overflow-hidden shadow-card group hover:-translate-y-1 transition-transform duration-300">
<div class="aspect-[4/5] relative overflow-hidden bg-surface-container">
<img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBYvbbfJj0LDUY6cRPJN5WFFxRII-6pw4L1Jg5ZwmHEGp-e35k2KCIfafqoqJda5T2i_ro17kfMPxoUcYw-_E9MVCpw9ElplR4P_aXC3jpfWZM8qlB3MI5YP2xexGOV8ByN-Ulz7A9jk9ikhIXck_K4_TgAyIy6S7DmZix_mi3eWWDhICJNG-JXyOLbEjH2DqBOO0ANUHzFSU9fnAJz76ScdjAlwTIapN6CjPKb6zvOk28UIbini_MFDdXtogk2wjnEOx2qYkedO4Q"/>
<button class="absolute top-4 right-4 bg-surface/80 backdrop-blur-md p-2 rounded-full text-primary shadow-sm"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">favorite</span></button>
</div>
<div class="p-6"><div class="flex justify-between items-start mb-2"><h3 class="text-xl font-headline font-semibold text-on-surface">手工陶艺纹理花瓶</h3><span class="text-primary font-bold">¥ 280</span></div><p class="text-on-surface-variant text-sm mb-4">Sahara 极简系列 - 温暖亚麻质感</p><button class="w-full py-3 bg-primary text-on-primary rounded-lg text-sm font-bold tracking-wide hover:opacity-90">加入购物车</button></div>
</div>
<div class="bg-surface-container-low rounded-xl overflow-hidden shadow-card group hover:-translate-y-1 transition-transform duration-300">
<div class="aspect-[4/5] relative overflow-hidden bg-surface-container">
<img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAt-46XIzcZlk4NVxxw9uW0ygdch8BVrnZbzbopfAfPJe7SK-5ZQur3GjsP2AxKG7CpOLXVatRbYLNuneaunG5J7eOxfkl3xWaXgbaXVoeAHoxZwuKJVHZsMpaPnROqGx81i8v8T01uHPz8CSrWbCh-aNtUcMOfLlI8g6nPlehrbajR5_sOg88ioZaS-LgifjKZEqckBdX4Cz0_peiclQcMPRNwMa5AyZYOC836f3mTKV1g-O_GXwfr9TUYC2sJPMzVLOn0jM52-cA"/>
<button class="absolute top-4 right-4 bg-surface/80 backdrop-blur-md p-2 rounded-full text-primary shadow-sm"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">favorite</span></button>
</div>
<div class="p-6"><div class="flex justify-between items-start mb-2"><h3 class="text-xl font-headline font-semibold text-on-surface">自然棉麻床品套装</h3><span class="text-primary font-bold">¥ 1,240</span></div><p class="text-on-surface-variant text-sm mb-4">100% 纯天然长绒棉，呼吸感触感</p><button class="w-full py-3 border border-outline text-primary rounded-lg text-sm font-bold tracking-wide hover:bg-surface-container-high">查看详情</button></div>
</div>
</div>
<div class="hidden grid grid-cols-1 md:grid-cols-3 gap-6 opacity-0 transition-opacity duration-300" id="content-drafts">
<div class="bg-surface-container-highest border-2 border-dashed border-outline-variant flex flex-col items-center justify-center p-8 rounded-xl h-[400px] hover:border-primary transition-colors cursor-pointer group"><span class="material-symbols-outlined text-4xl text-on-surface-variant mb-4 group-hover:text-primary">add_circle</span><p class="font-medium text-on-surface-variant">开启新创作</p></div>
<div class="bg-surface-container-low rounded-xl overflow-hidden shadow-card relative h-[400px]">
<div class="h-2/3 bg-surface-container overflow-hidden"><img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA03Msu7_Ouh03U-tLA9h7lYyvCTFw8h86SlR0FshlWVChfihygU8oYYtmw5wyWhv0DdWAX-0hE_43VbdUHO8dTJOpsY9UvYa2MOv5Jj6EFwSO1Odse-5MdxfTeNW19FKUsNSfro0wkNvMv32GuU4OfB62lbjjzyTm8MeL6vGwdsDqCNrOWc-ad4j6mIkf6KWd42pwa5In3gmIlzTfMTeoAG50CbixPd89zb8nZdm-tkyi5l_EQbeOWei95SaYLOCGRI2beOwMiSa4"/></div>
<div class="p-4 h-1/3 flex flex-col justify-between"><div><h3 class="font-headline text-lg font-bold">Sahara 扶手椅方案</h3><p class="text-xs text-on-surface-variant mt-1">最后编辑：2小时前</p></div><div class="flex justify-between items-center"><span class="text-xs px-2 py-1 bg-secondary-container text-on-secondary-container rounded-full">草稿 #04</span><button class="material-symbols-outlined text-primary hover:bg-surface-container-high p-2 rounded-full">edit</button></div></div>
</div>
<div class="bg-surface-container-low rounded-xl overflow-hidden shadow-card relative h-[400px]">
<div class="h-2/3 bg-surface-container overflow-hidden"><img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuANqnfF4MB6DLQxr8sWHNLDR7iune1C4dUaTmElC26SvFhvlOGAfO1Vtul5DuSxLx2V0otwvQvgvon-7VTso_0nblqITFM9Vq8wu8Y2ZWO1y5BGILcGpK7ZRFJY2BXqH7hERTFztsB7pYuFZImzQhzsyUK4-R0XNN0C8gzlE9YINmqpDSktqdCT5xftZTW60-EP8xh580OYuFLwFFfmW4l8UGGv2Xyn5I2VtkS4URTsJg4oVQcJwlc54Y-_amqMI0Nt0SKZAtQlMEo"/></div>
<div class="p-4 h-1/3 flex flex-col justify-between"><div><h3 class="font-headline text-lg font-bold">抽象极简装饰画</h3><p class="text-xs text-on-surface-variant mt-1">最后编辑：昨天</p></div><div class="flex justify-between items-center"><span class="text-xs px-2 py-1 bg-secondary-container text-on-secondary-container rounded-full">草稿 #02</span><button class="material-symbols-outlined text-primary hover:bg-surface-container-high p-2 rounded-full">edit</button></div></div>
</div>
</div>
</main>
<nav class="fixed bottom-0 w-full z-50 flex justify-around items-center px-4 py-2 bg-surface border-t border-outline-variant">
<a href="/" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-all"><span class="material-symbols-outlined">home</span><span class="text-[10px] mt-1">Home</span></a>
<a href="/design" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-all"><span class="material-symbols-outlined">draw</span><span class="text-[10px] mt-1">Design</span></a>
<a href="/cart" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-all"><span class="material-symbols-outlined">shopping_cart</span><span class="text-[10px] mt-1">Cart</span></a>
<a href="/shop" class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:text-primary transition-all"><span class="material-symbols-outlined">storefront</span><span class="text-[10px] mt-1">Shop</span></a>
<a href="/person" class="flex flex-col items-center justify-center bg-primary/10 text-primary rounded-lg px-3 py-1"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">person</span><span class="text-[10px] mt-1">Profile</span></a>
</nav>
<script>
function switchTab(tab) {
    const fav=document.getElementById('content-favorites'), draft=document.getElementById('content-drafts'), favBtn=document.getElementById('tab-favorites'), draftBtn=document.getElementById('tab-drafts');
    if(tab==='favorites'){
        fav.classList.remove('hidden'); setTimeout(()=>fav.classList.add('opacity-100'),10);
        draft.classList.add('hidden'); draft.classList.remove('opacity-100');
        favBtn.classList.add('text-primary','border-b-2','border-primary'); favBtn.classList.remove('text-on-surface-variant/60');
        draftBtn.classList.remove('text-primary','border-b-2','border-primary'); draftBtn.classList.add('text-on-surface-variant/60');
    } else {
        draft.classList.remove('hidden'); setTimeout(()=>draft.classList.add('opacity-100'),10);
        fav.classList.add('hidden'); fav.classList.remove('opacity-100');
        draftBtn.classList.add('text-primary','border-b-2','border-primary'); draftBtn.classList.remove('text-on-surface-variant/60');
        favBtn.classList.remove('text-primary','border-b-2','border-primary'); favBtn.classList.add('text-on-surface-variant/60');
    }
}
</script>
</MainLayout>
