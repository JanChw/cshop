---
import MainLayout from '../../layouts/MainLayout.astro'
---

<MainLayout title="个人素材库">
<header class="w-full top-0 sticky z-50 bg-surface/80 backdrop-blur-md border-b border-outline-variant flex justify-between items-center px-container-margin h-16">
<div class="flex items-center gap-2">
<button class="material-symbols-outlined text-on-surface-variant hover:bg-surface-container transition-colors p-2 rounded-full">arrow_back</button>
<h1 class="text-xl font-bold text-primary">个人素材库</h1>
</div>
<div class="w-10 h-10 rounded-full overflow-hidden border border-outline-variant"><img alt="User" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBOxnDs0-rYmql29hHshfkD3oIt4fKN-_B6j-5_xc-xbHNwj9SlP3PTxQecg4PTmcTDqsSPdKB_klkDT9VrmswtIfg6i66BduGVrkVe10eFSvifad6wq35ysPsLLHZKGWhrRw3v75X7Vz8flAz1nlw9osC8fq3Hk4eM5BAflDdvC5uvsOlEDXLUwzXoM6knd2SKtAphF19S_9GlYrYtcTkzMUrLw6eqPuwFcYIOLnOZaFusiw5gLRuQfShMsPewEloxdjvzvIXJIqg"/></div>
</header>
<main class="px-container-margin space-y-4 pt-4 pb-24">
<div class="relative"><span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
<input class="w-full h-12 pl-12 pr-4 bg-surface-container-lowest border border-outline-variant rounded-lg text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="查找素材名称..." type="text"/></div>
<div class="flex gap-3 overflow-x-auto no-scrollbar py-2">
<button class="px-6 py-2 rounded-lg bg-primary text-on-primary font-semibold text-sm whitespace-nowrap">全部</button>
<button class="px-6 py-2 rounded-lg bg-surface-container-high text-on-surface-variant font-semibold text-sm hover:bg-surface-container-highest whitespace-nowrap">上传</button>
<button class="px-6 py-2 rounded-lg bg-surface-container-high text-on-surface-variant font-semibold text-sm hover:bg-surface-container-highest whitespace-nowrap">收藏</button>
<button class="px-6 py-2 rounded-lg bg-surface-container-high text-on-surface-variant font-semibold text-sm hover:bg-surface-container-highest whitespace-nowrap">草稿</button>
</div>
<section class="grid grid-cols-2 gap-4 pb-8">
<div class="group relative bg-surface-container-lowest border border-outline-variant rounded-lg overflow-hidden flex flex-col aspect-[4/5] hover:border-primary transition-all">
<div class="flex-1 bg-surface-variant/30 overflow-hidden relative"><img class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDO5kBoOStIIg-c4gmVAyifasihv9La4XNflyjZRYznINoVEPkpJuT97AY0eqCtg11pEQ9x9TeRGsa6wa6rkgshyAoScsFH5KqYrk92mumUjtLgqt5U-xHw0Y0H2Bn64Y5y9BnkWYeO4FRi9Tz4eRQYtt0gqVtNUs9I5MON4w9R6PwSIjlSLkO6kNjo6rsYG1mlkrpdPKv56Cq0Yi8gwo_1Qps1arKeKS_DFpHZInP-dri6qymBMfrje4Fd5DPBmaVjidhPmZCxuIc"/>
<div class="absolute top-2 right-2"><button class="bg-white/90 backdrop-blur-md p-1.5 rounded-lg shadow-sm text-on-surface-variant hover:text-error"><span class="material-symbols-outlined text-base">delete</span></button></div>
</div>
<div class="p-3"><p class="font-semibold text-sm text-on-surface truncate">未来主义蓝色波形</p><p class="text-[10px] text-outline mt-1 uppercase tracking-wider font-bold">PNG • 2.4 MB</p></div></div>
<div class="group relative bg-surface-container-lowest border border-outline-variant rounded-lg overflow-hidden flex flex-col aspect-[4/5] hover:border-primary transition-all">
<div class="flex-1 bg-surface-variant/30 overflow-hidden relative"><img class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDowFrLGLX8Df1z6aWGYKXm88YUy3TbzjNeH1XWdzWs7qKRi_Uix4u4vxGGM5w0FAT1mKZ841qaYuXy17HPtltJot051Qgk21rMamdHPJrqk8GFArIwm5sFI4-VU7FaipuK9GSV1vmMaupHzQX-n28VT4_AWAw5fFkn86qeBNHMvGcuyYsegWQbo150RFL7V1jcYHdKus13UfUuyRtHe8yQSNbIaEXvJqc6tgXe3OIb_3scSyetJGiLmlpZkYL7DsNIGgGUzH_YY_w"/>
<div class="absolute top-2 right-2"><button class="bg-white/90 backdrop-blur-md p-1.5 rounded-lg shadow-sm text-on-surface-variant hover:text-error"><span class="material-symbols-outlined text-base">delete</span></button></div>
</div>
<div class="p-3"><p class="font-semibold text-sm text-on-surface truncate">简约都市插画</p><p class="text-[10px] text-outline mt-1 uppercase tracking-wider font-bold">SVG • 450 KB</p></div></div>
<div class="group relative bg-surface-container-lowest border border-outline-variant rounded-lg overflow-hidden flex flex-col aspect-[4/5] hover:border-primary transition-all">
<div class="flex-1 bg-surface-variant/30 overflow-hidden relative"><img class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDk5w_Enc9O_kR3uN84qHJgKd7d-w8oJ-hHsrRKX1thfMp9C-LhtZH_rvewk26ZEvb4pZ9aKQeTsjwIC_FT2XTTHTMM50BGu3j1iskIXs7tobVKDlh70_eOIF5IrWzSJsAWbNrWHkjMjWMhutG8br-wN_i4JyYusWOJlo0zERLRRY_Mh1_Hbp8a1Q5Doe0KPTYrGPlMwWfGdKuMc4UP-jwqdjuLzm1K7C7NeHdw4px-eQXwbXQr3ah7RXjJwv9TeNUTr7ZDZJETK3M"/>
<div class="absolute top-2 right-2"><button class="bg-white/90 backdrop-blur-md p-1.5 rounded-lg shadow-sm text-on-surface-variant hover:text-error"><span class="material-symbols-outlined text-base">delete</span></button></div>
</div>
<div class="p-3"><p class="font-semibold text-sm text-on-surface truncate">抽象流动纹理</p><p class="text-[10px] text-outline mt-1 uppercase tracking-wider font-bold">JPG • 4.1 MB</p></div></div>
<div class="group relative bg-surface-container-lowest border border-outline-variant rounded-lg overflow-hidden flex flex-col aspect-[4/5] hover:border-primary transition-all">
<div class="flex-1 bg-surface-variant/30 overflow-hidden relative flex items-center justify-center">
<div class="text-center opacity-40"><span class="material-symbols-outlined text-4xl block mb-2 text-on-surface-variant">draw</span><p class="font-semibold text-xs text-on-surface-variant">未命名草稿</p></div>
<div class="absolute top-2 right-2"><button class="bg-white/90 backdrop-blur-md p-1.5 rounded-lg shadow-sm text-on-surface-variant hover:text-primary"><span class="material-symbols-outlined text-base">edit</span></button></div>
</div>
<div class="p-3"><p class="font-semibold text-sm text-on-surface truncate">新设计 - 2024.03</p><p class="text-[10px] text-outline mt-1 uppercase tracking-wider font-bold">Draft • Editable</p></div></div>
</section>
</main>
<button class="fixed bottom-24 right-5 w-14 h-14 bg-primary text-on-primary rounded-xl shadow-lg shadow-primary/20 flex items-center justify-center active:scale-90 z-40"><span class="material-symbols-outlined">add</span></button>
<nav class="fixed bottom-0 left-0 w-full flex justify-around items-center bg-surface/95 backdrop-blur-lg border-t border-outline-variant px-2 py-3 z-50">
<button class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container rounded-lg"><span class="material-symbols-outlined">home</span><span class="text-[10px] font-bold mt-0.5">首页</span></button>
<button class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container rounded-lg"><span class="material-symbols-outlined">draw</span><span class="text-[10px] font-bold mt-0.5">设计</span></button>
<button class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container rounded-lg"><span class="material-symbols-outlined">storefront</span><span class="text-[10px] font-bold mt-0.5">商店</span></button>
<button class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container rounded-lg"><span class="material-symbols-outlined">shopping_cart</span><span class="text-[10px] font-bold mt-0.5">购物车</span></button>
<button class="flex flex-col items-center justify-center bg-primary text-on-primary rounded-lg px-4 py-1"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">person</span><span class="text-[10px] font-bold mt-0.5">我的</span></button>
</nav>
</MainLayout>
