---
import MainLayout from '../layouts/MainLayout.astro'
---

<MainLayout title="注册">
<!-- Top Navigation -->
<header class="fixed top-0 w-full z-50 bg-surface flex justify-between items-center px-6 h-16 shadow-sm">
<div class="flex items-center">
<button onclick="history.back()" class="text-on-surface-variant hover:opacity-80 transition-opacity active:scale-95">
<span class="material-symbols-outlined">close</span>
</button>
</div>
<div class="absolute left-1/2 -translate-x-1/2">
<h1 class="font-headline text-2xl font-bold text-primary tracking-tight">ByChooow</h1>
</div>
<div class="w-6"></div>
</header>

<main class="flex-grow flex items-center justify-center px-4 pt-24 pb-12">
<div class="w-full max-w-md">
<div class="text-center mb-10">
<h2 class="font-headline text-4xl font-bold text-on-surface mb-3 tracking-tight">创建您的风格</h2>
<p class="text-on-surface-variant text-sm leading-relaxed max-w-xs mx-auto">
            加入创作者社区，开始设计您的专属服饰
        </p>
</div>
<div class="bg-surface-container-lowest p-8 rounded-xl shadow-card border border-outline-variant/60">
<form class="space-y-5" onsubmit="event.preventDefault()">
<div class="space-y-1.5">
<label class="block text-[11px] font-semibold uppercase tracking-widest text-on-surface-variant ml-1">全名</label>
<input class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-200 outline-none text-on-surface placeholder:text-outline" placeholder="您的称呼" type="text"/>
</div>
<div class="space-y-1.5">
<label class="block text-[11px] font-semibold uppercase tracking-widest text-on-surface-variant ml-1">邮箱或手机号</label>
<input class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-200 outline-none text-on-surface placeholder:text-outline" placeholder="example@chooow.com" type="text"/>
</div>
<div class="space-y-1.5 relative">
<label class="block text-[11px] font-semibold uppercase tracking-widest text-on-surface-variant ml-1">密码</label>
<input class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-200 outline-none text-on-surface placeholder:text-outline" placeholder="至少 8 位字符" type="password"/>
<button class="absolute right-3 top-[34px] text-on-surface-variant opacity-60 hover:opacity-100 transition-opacity" type="button">
<span class="material-symbols-outlined text-[20px]">visibility</span>
</button>
</div>
<div class="space-y-1.5">
<label class="block text-[11px] font-semibold uppercase tracking-widest text-on-surface-variant ml-1">确认密码</label>
<input class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-200 outline-none text-on-surface placeholder:text-outline" placeholder="再次输入密码" type="password"/>
</div>
<div class="flex items-start gap-3 pt-2">
<div class="flex items-center h-5">
<input class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary/30 transition-all cursor-pointer" id="terms" type="checkbox"/>
</div>
<label class="text-xs text-on-surface-variant leading-relaxed cursor-pointer select-none" for="terms">
                我已阅读并同意 <a class="text-primary hover:underline transition-all" href="#">用户协议</a> 与 <a class="text-primary hover:underline transition-all" href="#">隐私条款</a>。
            </label>
</div>
<button class="w-full bg-primary text-white font-bold py-4 rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all duration-200 mt-4 tracking-wide" type="submit">
            注册
        </button>
</form>
<div class="relative my-8 text-center">
<div class="absolute inset-0 flex items-center">
<span class="w-full border-t border-outline-variant opacity-40"></span>
</div>
<span class="relative px-4 bg-surface-container-lowest text-[10px] uppercase tracking-[0.2em] text-outline font-semibold">或其他注册方式</span>
</div>
<div class="grid grid-cols-2 gap-4">
<button class="flex items-center justify-center gap-3 py-3 border border-outline-variant rounded-lg hover:bg-surface-variant transition-colors active:scale-95 duration-200">
<svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"></path><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"></path><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"></path><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"></path></svg>
<span class="text-xs font-semibold text-on-surface">Google</span>
</button>
<button class="flex items-center justify-center gap-3 py-3 border border-outline-variant rounded-lg hover:bg-surface-variant transition-colors active:scale-95 duration-200">
<svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M17.05 20.28c-.96.95-2.43.95-3.39 0-1.2-1.2-3.39-1.2-4.59 0-.96.95-2.43.95-3.39 0-1.81-1.81-2.43-4.39-1.63-6.61.85-2.36 3.09-3.92 5.6-3.92.54 0 1.07.11 1.57.32.74.31 1.57.31 2.31 0 .5-.21 1.03-.32 1.57-.32 2.51 0 4.75 1.56 5.6 3.92.8 2.22.18 4.8-1.63 6.61z" fill="currentColor"></path><path d="M12 2c-.08 1.43.68 2.78 1.93 3.47.28.15.6.23.93.23.1 0 .21 0 .31-.01.03-1.46-.72-2.83-2-3.52-.3-.16-.63-.24-.96-.24-.07 0-.14.01-.21.07z" fill="currentColor"></path></svg>
<span class="text-xs font-semibold text-on-surface">Apple</span>
</button>
</div>
</div>
<div class="mt-8 text-center">
<p class="text-sm text-on-surface-variant">
            已有账号？ <a class="text-primary font-bold hover:underline underline-offset-4 decoration-primary/30 transition-all" href="/login">登录</a>
</p>
</div>
</div>
</main>

<div class="fixed top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-[100px] -z-10 pointer-events-none"></div>
<div class="fixed bottom-[-10%] right-[-10%] w-[30%] h-[30%] bg-tertiary/5 rounded-full blur-[80px] -z-10 pointer-events-none"></div>

<script>
// Password visibility toggle
document.querySelectorAll('.material-symbols-outlined.text-\\[20px\\]').forEach(icon => {
    if (icon.textContent.trim() === 'visibility') {
        icon.parentElement.addEventListener('click', function() {
            const input = this.closest('.space-y-1\\.5').querySelector('input');
            if (input.type === 'password') { input.type = 'text'; this.querySelector('.material-symbols-outlined').textContent = 'visibility_off'; }
            else { input.type = 'password'; this.querySelector('.material-symbols-outlined').textContent = 'visibility'; }
        });
    }
});

// Focus label effect
document.querySelectorAll('input, textarea').forEach(input => {
    input.addEventListener('focus', () => {
        const label = input.closest('.space-y-1\\.5')?.querySelector('label');
        if (label) label.classList.add('text-primary');
    });
    input.addEventListener('blur', () => {
        const label = input.closest('.space-y-1\\.5')?.querySelector('label');
        if (label) label.classList.remove('text-primary');
    });
});

// Form submission
document.querySelector('form')?.addEventListener('submit', function(e) {
    e.preventDefault();
    document.querySelectorAll('.error-msg').forEach(el => el.remove());
    const inputs = this.querySelectorAll('input:not([type="checkbox"])');
    inputs.forEach(el => el.classList.remove('border-error'));
    
    const name = inputs[0];
    const email = inputs[1];
    const pwd = inputs[2];
    const confirmPwd = inputs[3];
    const terms = document.getElementById('terms');
    let valid = true;
    
    if (!name.value.trim()) { showError(name, '请输入姓名'); valid = false; }
    if (!email.value.trim()) { showError(email, '请输入邮箱或手机号'); valid = false; }
    if (!pwd.value) { showError(pwd, '请输入密码'); valid = false; }
    else if (pwd.value.length < 8) { showError(pwd, '密码至少 8 位'); valid = false; }
    if (pwd.value !== confirmPwd.value) { showError(confirmPwd, '两次密码不一致'); valid = false; }
    if (!terms.checked) {
        terms.classList.add('border-error');
        const err = document.createElement('p');
        err.className = 'error-msg text-error text-xs mt-1';
        err.textContent = '请先同意用户协议';
        terms.closest('.flex.items-start').appendChild(err);
        valid = false;
    }
    
    if (!valid) return;
    
    const btn = this.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="inline-block animate-spin material-symbols-outlined">progress_activity</span> 注册中...';
    setTimeout(() => {
        btn.innerHTML = '<span class="material-symbols-outlined">check_circle</span> 注册成功';
        btn.classList.remove('bg-primary');
        btn.classList.add('bg-green-600');
        setTimeout(() => { window.location.href = '/login'; }, 1000);
    }, 1500);
});

function showError(el, msg) {
    el.classList.add('border-error');
    const err = document.createElement('p');
    err.className = 'error-msg text-error text-xs mt-1 ml-1';
    err.textContent = msg;
    el.closest('.space-y-1\\.5')?.appendChild(err);
}

// Touch active effect for buttons
document.querySelectorAll('button').forEach(btn => {
    btn.addEventListener('touchstart', function() { this.style.transform = 'scale(0.97)'; });
    btn.addEventListener('touchend', function() { this.style.transform = 'scale(1)'; });
});
</script>
</MainLayout>
