---
import MainLayout from '../layouts/MainLayout.astro'
import OrderCard from '../components/ui/OrderCard.tsx'

const orders = [
  { orderNumber: '202310248892', status: 'pending', items: [{ product: { name: '定制创意印花 T恤', image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCaC72ba8f08_URhorLNkgefycLVXdsAebkKb0DWM9R0x2jjZYcJDI1TXOwwJLarKElSVbCF-GK_IfS2hmBidgIfIYYpSDc1OykAz1uDQ2idOblKQy5gbdPENF6zsj8uALWgAi94K4ElNBkYHVL0NEgRfNO4YIaSSWMeq6ey56ES9OixPyyAo4RJaJ-DZ0b6EibFuW8AY68D68LgigYK1b4eGoudqIeTDWFbK-eR5S55FBXiBn_9_InIEpLZQFXK3A01x9dm6rUNE8' }, quantity: 1, size: 'L', color: '极简黑' }], total: 199, createdAt: '2023-10-24', designer: 'Jordan.Design' },
  { orderNumber: '202310224510', status: 'shipping', items: [{ product: { name: '重磅插肩袖 连帽衫', image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCTmTCGjOaxXei0_M2G9RjDCYMAhNPqnivR7yy-aH_UxzutfFVNt58liP5KpuKYmwtGHTDddLf5-qdVVdoA-t0c8yQY7F3q4_E2K_H9Ze9gI81N9hXYMaZhjPlDnaQ10ADP4fGa4KXi54o0Zaw_esGv4vZmyIGxXrrG1sRk7bxFOI9CYpB1MKdBDAaFdUFRcjbti-4o8QBU4cByL0JCXQJPxgXXO2gfesw7CciasXyc7NEggiJiGYj_ctFTstbzYH6Eoejdq6PNVJ8' }, quantity: 1, size: 'XL', color: '霜灰色' }], total: 459, createdAt: '2023-10-22', designer: 'Studio_99' },
  { orderNumber: '202309153321', status: 'completed', items: [{ product: { name: '自然系列 线条插画 T恤', image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuBz3uIsvYz2iBLdX8a_yZxhSpphxxn4nFBKNe5rdrMz841oHVwjmFoZ7N_7p_mnBZJgRkVWF-4X3P_x6Tr-PDy-cd_yV5hBAYkSdykm4G-_PMITLmEEXoeLLsKMM8f53HM8ASn5ezWrCgaD_5juexO4waMlHDONquPuKePoD048IRn_y1nTBpp_Nr8utEjszNeybVnnAirsNGN7IkBh5QPjDnF2eqfpYq75caqj5x9FEmMg0TW0WSYBXgdRsqd3by_kIEJdljDh77E' }, quantity: 1, size: 'M', color: '珍珠白' }], total: 229, createdAt: '2023-09-15' }
]
---

<MainLayout title="订单管理">
<!-- Top App Bar -->
<header class="w-full top-0 sticky z-40 bg-surface/90 backdrop-blur-md border-b border-outline-variant flex justify-between items-center px-container-margin py-stack-sm h-16">
<div class="flex items-center gap-4">
<button onclick="history.back()" class="material-symbols-outlined text-on-surface hover:bg-surface-container transition-colors p-2 rounded-full active:scale-95 duration-150">arrow_back</button>
<h1 class="text-headline-lg-mobile font-bold text-on-surface">订单管理</h1>
</div>
<div class="flex items-center gap-2">
<button class="material-symbols-outlined text-on-surface-variant hover:bg-surface-container transition-colors p-2 rounded-full">search</button>
<div class="w-8 h-8 rounded-full bg-surface-container-highest overflow-hidden border border-outline-variant">
<img alt="User" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCuDhS4yEY8a1mqfGqH5KlQoJL4VCbCdaPM-NjxGNjLm-MxE3C5jvvfng_YoLSq676kL-ecWXssjfBI3VTRkG64nVfLW-ld-wSfU8v61wHCFFN3w6ZP2z2v_WvYjr9JI4zj2FIfhY1d4F13Ued1qu41zO9msOiG9pnKzTAzxD13sIN0VHv0ll479RGTFdETBFMjcKsP77hYW0epxGi1Ip2z0340MQ4j-3u-WOVXcjzFfElZhoQSPTnbDGki4brVQr7kEA_m2nsbvWQ"/>
</div>
</div>
</header>

<!-- Navigation Tabs -->
<nav class="sticky top-16 z-30 bg-surface border-b border-outline-variant px-container-margin overflow-x-auto no-scrollbar">
<div class="flex items-center gap-8 h-12 min-w-max">
<a class="text-label-md text-primary border-b-2 border-primary h-full flex items-center px-1" href="#">全部</a>
<a class="text-label-md text-on-surface-variant hover:text-on-surface transition-colors h-full flex items-center px-1" href="#">待付款</a>
<a class="text-label-md text-on-surface-variant hover:text-on-surface transition-colors h-full flex items-center px-1" href="#">待收货</a>
<a class="text-label-md text-on-surface-variant hover:text-on-surface transition-colors h-full flex items-center px-1" href="#">已完成</a>
<a class="text-label-md text-on-surface-variant hover:text-on-surface transition-colors h-full flex items-center px-1" href="#">已取消</a>
</div>
</nav>

<!-- Main Content -->
<main class="px-container-margin py-stack-lg space-y-6 max-w-[1200px] mx-auto pb-32">
{orders.map((order) => (
  <OrderCard
    orderNumber={order.orderNumber}
    status={order.status}
    items={order.items}
    total={order.total}
    designer={order.designer}
    createdAt={order.createdAt}
  />
))}
</main>

<!-- Bottom Navigation Bar (Mobile) -->
<nav class="fixed bottom-0 left-0 w-full flex justify-around items-center bg-surface px-2 py-3 z-50 border-t border-outline-variant shadow-[0_-2px_10px_rgba(0,0,0,0.02)]">
<a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container-low transition-colors active:scale-90 duration-100" href="/">
<span class="material-symbols-outlined mb-1">home</span>
<span class="text-label-md">Home</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container-low transition-colors active:scale-90 duration-100" href="/design">
<span class="material-symbols-outlined mb-1">brush</span>
<span class="text-label-md">Design</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container-low transition-colors active:scale-90 duration-100" href="/shop">
<span class="material-symbols-outlined mb-1">storefront</span>
<span class="text-label-md">Shop</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant px-3 py-1 hover:bg-surface-container-low transition-colors active:scale-90 duration-100" href="/cart">
<span class="material-symbols-outlined mb-1">shopping_cart</span>
<span class="text-label-md">Cart</span>
</a>
<a class="flex flex-col items-center justify-center bg-primary-container text-primary rounded-lg px-3 py-1 transition-colors active:scale-90 duration-100" href="/person">
<span class="material-symbols-outlined mb-1" style="font-variation-settings: 'FILL' 1;">person</span>
<span class="text-label-md">Profile</span>
</a>
</nav>

<script>
const tabs = document.querySelectorAll('nav:not(.fixed) a');
tabs.forEach(tab => {
    tab.addEventListener('click', (e) => {
        e.preventDefault();
        tabs.forEach(t => { t.classList.remove('text-primary', 'border-primary', 'border-b-2'); t.classList.add('text-on-surface-variant'); });
        tab.classList.add('text-primary', 'border-primary', 'border-b-2');
        tab.classList.remove('text-on-surface-variant');
        const status = tab.textContent.trim();
        document.querySelectorAll('.space-y-6 > div').forEach(card => {
            const statusEl = card.querySelector('.border-b .text-label-md:last-child');
            if (!statusEl) return;
            const cardStatus = statusEl.textContent.trim();
            card.style.display = (status === '全部' || cardStatus === status) ? '' : 'none';
        });
    });
});
</script>

<style>
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
</MainLayout>
