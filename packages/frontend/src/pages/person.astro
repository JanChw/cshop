---
import MainLayout from '../layouts/MainLayout.astro'
---

<MainLayout title="个人中心">
<nav class="fixed top-0 left-0 w-full z-50 bg-surface/80 backdrop-blur-md border-b border-outline-variant">
<div class="flex justify-between items-center px-container-margin h-14 w-full max-w-7xl mx-auto">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-primary">menu</span>
<span class="text-title-md font-bold text-primary">ByChooow</span>
</div>
<div class="w-9 h-9 rounded-full overflow-hidden border border-outline-variant">
<img alt="Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCEsnMM_Y5WOFUgqqnZnQA8TyDeFPIEPiMK6jpwsezXGNkwHqz-U3WA_KlwiJ5V0ztGpOxuYXac0SgBvi84VTt3KwPh4OgHFdAuX3uAoVluVF4Nt367Jgv7rdwce-RzRfUQeioe01bZZOcnEuqY9HsMmiLq9qRw693yu4mi17emXzOaP4ghtdxHzFxKyg52Ocrwd4lJQwJw4XUBbwwTC2RX7gXFzS4QC5FlMGnfZ8DdohPVuruzTJqnBJ-VMlsvTD_V_xxSkPjFnZM"/>
</div>
</div>
</nav>
<main class="pt-14 pb-24 max-w-7xl mx-auto px-container-margin">
<header class="py-stack-lg flex flex-col items-center text-center">
<div class="relative mb-stack-md">
<div class="w-24 h-24 rounded-full p-0.5 bg-gradient-to-tr from-primary to-[#fbd38d]">
<img alt="Creator Avatar" class="w-full h-full rounded-full object-cover border-4 border-surface" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCXCBwssGe-nsT__IhXnIu4UtfnPy12m8VS3XLS_-O-sOvwCw74FJGHkrE5bU3yzyze7A59HE9t1x9-z-5x5rWwA2RZ7iWwwRP8OmzM1nAgHmLqrZBWO_S7QA9Ci4Sq0e4XEsTfSV5tlW8fADA8SG-ht1FgsevRFcnkl14olqe5gdw2Z0-NFXXL1cLg1IYt5MilzsBGA9Eyj7Ny7pvEVVw4eJlCGEwzhzbT638oJ8Hur3wYkVxGiTuSOvdud7jczu1COJNoTaNh0Ro"/>
</div>
<div class="absolute bottom-0 right-0 bg-primary text-white text-[10px] px-2 py-0.5 rounded-full font-bold shadow-sm">LV.4</div>
</div>
<h1 class="text-headline-lg-mobile text-on-surface">陈小周</h1>
<p class="text-body-sm text-secondary mb-stack-md">高级定制设计师 · Creator</p>
<div class="flex gap-stack-sm">
<div class="flex items-center gap-1 px-3 py-1 bg-surface-container rounded-full border border-outline-variant"><span class="material-symbols-outlined text-xs text-primary" style="font-variation-settings:'FILL' 1">check_circle</span><span class="text-label-md">微信已绑定</span></div>
<div class="flex items-center gap-1 px-3 py-1 bg-surface-container rounded-full border border-outline-variant"><span class="material-symbols-outlined text-xs text-outline">link_off</span><span class="text-label-md">QQ未绑定</span></div>
</div>
</header>
<section class="grid grid-cols-2 md:grid-cols-4 gap-gutter mb-stack-lg">
<div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant flex flex-col items-center"><span class="text-headline-lg-mobile text-primary">24</span><span class="text-label-md text-secondary">我的设计</span></div>
<div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant flex flex-col items-center"><span class="text-headline-lg-mobile text-primary">12</span><span class="text-label-md text-secondary">已下单</span></div>
<div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant flex flex-col items-center"><span class="text-headline-lg-mobile text-primary">156</span><span class="text-label-md text-secondary">获赞</span></div>
<div class="bg-surface-container-lowest p-stack-md rounded-xl border border-outline-variant flex flex-col items-center"><span class="text-headline-lg-mobile text-primary">890</span><span class="text-label-md text-secondary">积分</span></div>
</section>
<section class="mb-stack-lg">
<div class="flex items-center justify-between mb-stack-md">
<h2 class="text-title-md text-on-surface">我的作品廊</h2>
<div class="flex bg-surface-container rounded-lg p-1">
<button class="px-4 py-1 text-label-md bg-surface-container-lowest text-primary rounded-md shadow-sm transition-all" id="tab-drafts">草稿箱</button>
<button class="px-4 py-1 text-label-md text-secondary transition-colors hover:text-on-surface" id="tab-ordered">已订购</button>
</div>
</div>
<div class="grid grid-cols-2 md:grid-cols-3 gap-gutter">
<div class="group relative aspect-[4/5] bg-surface-container rounded-xl overflow-hidden border border-outline-variant hover:scale-[1.02] transition-transform">
<img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuArNJtz5id7l_kVqDy9q77UDFa00Qmzx3dTObH430lfddSQGRdF8NT40Hv-0ldAnftfKTRvMENRa_O4Y_s9Kyfw98e2o6z23_egbDGk-ITD0kC7bZpxAnNoaQrpwTAX43294R1EUTtY4DzTqrCZTPTHdpN837UjKudvw2iCyvFQ5ETWJFcHZtBVMrBJUB7dzTjjOIWwDYNAkbq1qfc2ZwNNCs26Zqvdp8WqNA9o2XcchdyWNVIx9Z1RqnRmCKytw56xNKD4oizaBOg"/>
<div class="absolute bottom-0 left-0 w-full p-stack-sm bg-gradient-to-t from-black/40 to-transparent"><p class="text-white text-label-md">极简未来主义 T-Shirt</p></div>
<div class="absolute top-2 right-2 px-2 py-0.5 bg-primary/90 backdrop-blur-md text-white text-[10px] rounded">草稿</div>
</div>
<div class="group relative aspect-[4/5] bg-surface-container rounded-xl overflow-hidden border border-outline-variant hover:scale-[1.02] transition-transform">
<img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCmdqsm1mnUTfH9dcXkf9lg2yAIUNE4haQRM1C7WXGjGLMuLJl4R9KbALdejGBBJ4fVTA29Xa8orLBbj37TXn_J4TIXkxBFddSyDnAG9NpXETZwj1gPzUKl1giPhtGTXfHYqVMajmBurVJbmkeioPdLUa-HXTuVVRpof34peFEeE_QiMCfxSHRiOnbs9YKWi_2mzX0t80VklNowIOwQJhN5zApa4tq5CKsIIHJgyIaRvB2BxoK_z5FojTe61tQe9cOs-MoBaR5lQLo"/>
<div class="absolute bottom-0 left-0 w-full p-stack-sm bg-gradient-to-t from-black/40 to-transparent"><p class="text-white text-label-md">朋克复兴 Hoodie</p></div>
</div>
<a href="/design" class="aspect-[4/5] bg-surface-container border-2 border-dashed border-outline-variant rounded-xl flex flex-col items-center justify-center gap-2 cursor-pointer hover:border-primary transition-colors group">
<span class="material-symbols-outlined text-primary text-3xl group-hover:scale-110 transition-transform">add_circle</span>
<span class="text-label-md text-secondary">开始创作</span>
</a>
</div>
</section>
<section class="mb-stack-lg">
<div class="flex items-center justify-between mb-stack-md">
<h2 class="text-title-md text-on-surface">订单概览</h2>
<a class="text-label-md text-primary flex items-center gap-1 hover:opacity-80" href="/order"><span>订单详情</span><span class="material-symbols-outlined text-xs">chevron_right</span></a>
</div>
<div class="bg-surface-container-low rounded-xl p-stack-md border border-outline-variant">
<div class="flex items-center justify-around py-2">
<a href="/order" class="flex flex-col items-center gap-1 text-secondary hover:text-primary transition-colors cursor-pointer"><span class="material-symbols-outlined text-2xl">account_balance_wallet</span><span class="text-label-md">待付款</span></a>
<div class="h-8 w-px bg-outline-variant"></div>
<a href="/order" class="flex flex-col items-center gap-1 text-secondary hover:text-primary transition-colors cursor-pointer"><span class="material-symbols-outlined text-2xl">package_2</span><span class="text-label-md">待发货</span></a>
<div class="h-8 w-px bg-outline-variant"></div>
<a href="/order" class="flex flex-col items-center gap-1 text-secondary hover:text-primary transition-colors cursor-pointer relative"><span class="material-symbols-outlined text-2xl">local_shipping</span><span class="text-label-md">运输中</span><div class="absolute -top-1 -right-1 w-2 h-2 bg-error rounded-full"></div></a>
<div class="h-8 w-px bg-outline-variant"></div>
<a href="/order" class="flex flex-col items-center gap-1 text-secondary hover:text-primary transition-colors cursor-pointer"><span class="material-symbols-outlined text-2xl">rate_review</span><span class="text-label-md">待评价</span></a>
</div>
</div>
</section>
<section class="mb-stack-lg">
<h2 class="text-title-md text-on-surface mb-stack-md">账户设置</h2>
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden">
<a href="/person/edit" class="flex items-center justify-between p-stack-md border-b border-outline-variant hover:bg-surface-container-low transition-colors cursor-pointer group">
<div class="flex items-center gap-stack-md"><span class="material-symbols-outlined text-secondary group-hover:text-primary">person</span><span class="text-body-lg">个人资料修改</span></div>
<span class="material-symbols-outlined text-outline">chevron_right</span>
</a>
<a href="/person/security" class="flex items-center justify-between p-stack-md border-b border-outline-variant hover:bg-surface-container-low transition-colors cursor-pointer group">
<div class="flex items-center gap-stack-md"><span class="material-symbols-outlined text-secondary group-hover:text-primary">shield</span><span class="text-body-lg">账号与安全</span></div>
<span class="material-symbols-outlined text-outline">chevron_right</span>
</a>
<a href="#" class="flex items-center justify-between p-stack-md border-b border-outline-variant hover:bg-surface-container-low transition-colors cursor-pointer group">
<div class="flex items-center gap-stack-md"><span class="material-symbols-outlined text-secondary group-hover:text-primary">notifications</span><span class="text-body-lg">消息推送设置</span></div>
<span class="material-symbols-outlined text-outline">chevron_right</span>
</a>
<a href="/person/assets" class="flex items-center justify-between p-stack-md border-b border-outline-variant hover:bg-surface-container-low transition-colors cursor-pointer group">
<div class="flex items-center gap-stack-md"><span class="material-symbols-outlined text-secondary group-hover:text-primary">perm_media</span><span class="text-body-lg">个人素材库</span></div>
<span class="material-symbols-outlined text-outline">chevron_right</span>
</a>
<a href="/person/help" class="flex items-center justify-between p-stack-md hover:bg-surface-container-low transition-colors cursor-pointer group">
<div class="flex items-center gap-stack-md"><span class="material-symbols-outlined text-secondary group-hover:text-primary">help</span><span class="text-body-lg">帮助与反馈</span></div>
<span class="material-symbols-outlined text-outline">chevron_right</span>
</a>
</div>
</section>
<button class="w-full py-4 text-error font-bold text-body-lg border border-error/20 rounded-xl hover:bg-error/5 transition-colors mb-stack-lg">退出登录</button>
</main>
<nav class="fixed bottom-0 left-0 w-full z-50 bg-surface/95 backdrop-blur-md border-t border-outline-variant flex justify-around items-center px-4 pb-4 pt-2">
<a href="/" class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-container-high rounded-xl transition-all"><span class="material-symbols-outlined">home</span><span class="text-label-md">首页</span></a>
<a href="/design" class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-container-high rounded-xl transition-all"><span class="material-symbols-outlined">rebase_edit</span><span class="text-label-md">设计</span></a>
<a href="/shop" class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-container-high rounded-xl transition-all"><span class="material-symbols-outlined">shopping_bag</span><span class="text-label-md">商店</span></a>
<a href="/person" class="flex flex-col items-center justify-center bg-primary/10 text-primary rounded-xl px-4 py-1 scale-95"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">person</span><span class="text-label-md">我的</span></a>
</nav>
<script>
document.getElementById('tab-drafts')?.addEventListener('click', ()=>{document.getElementById('tab-drafts')?.classList.add('bg-surface-container-lowest','text-primary','shadow-sm');document.getElementById('tab-drafts')?.classList.remove('text-secondary');document.getElementById('tab-ordered')?.classList.remove('bg-surface-container-lowest','text-primary','shadow-sm');document.getElementById('tab-ordered')?.classList.add('text-secondary');});
document.getElementById('tab-ordered')?.addEventListener('click', ()=>{document.getElementById('tab-ordered')?.classList.add('bg-surface-container-lowest','text-primary','shadow-sm');document.getElementById('tab-ordered')?.classList.remove('text-secondary');document.getElementById('tab-drafts')?.classList.remove('bg-surface-container-lowest','text-primary','shadow-sm');document.getElementById('tab-drafts')?.classList.add('text-secondary');});
</script>
</MainLayout>
