# cshop backend configuration
# Copy to .env and fill in values

# Server
PORT=3001
HOSTNAME=0.0.0.0
NODE_ENV=development

# Data directory (DB, uploads, stickers, backups all live here)
# DATA_DIR=./data

# Database (overrides DATA_DIR default)
# DB_PATH=./data/cshop.db

# File storage
# UPLOAD_DIR=./data/uploads
# STICKER_DIR=./data/stickers
# BACKUP_DIR=./data/backups
# UPLOAD_MAX_BYTES=10485760
# STICKER_MAX_BYTES=2097152

# CORS (comma-separated origins, or * for any)
# CORS_ORIGINS=http://localhost:4321,http://localhost:5173

# JWT (REQUIRED in production)
JWT_SECRET=change-me-to-a-long-random-string

# Rate limiting (set to 1 to disable, e.g. in tests)
# RATE_LIMIT_DISABLED=1

# ===== 邮件通知 (SMTP) =====
# 缺这 4 个变量时邮件通道会退化为 console 输出（开发期方便）
# 真实部署必须配，否则所有新订单/库存预警/注册通知都是 console

# 发件邮箱（同时也是 SMTP 登录账号）
EMAIL=your-email@qq.com

# SMTP 授权码 — 不是登录密码！
# - QQ 邮箱: 设置→账户→POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务 → 生成 16 位授权码
# - 163 邮箱: 设置→POP3/SMTP/IMAP → 客户端授权密码
# - Gmail:    需开启两步验证 + 生成"应用专用密码"
EMAIL_AUTH_PASSWORD=your-16char-auth-code

# SMTP 服务器地址
SEND_EMAIL=smtp.qq.com

# SMTP 端口
# - 465 = SSL/TLS（推荐，国内邮箱大多用这个）
# - 587 = STARTTLS（Gmail / Outlook 用）
SEND_PORT=465

# 各家常见配置（参考）：
#   QQ 邮箱:    smtp.qq.com:465        (授权码 16 位)
#   Foxmail:    smtp.qq.com:465        (同 QQ)
#   163 邮箱:   smtp.163.com:465 或 :25
#   Gmail:      smtp.gmail.com:587     (需应用专用密码)
#   Outlook:    smtp.office365.com:587
#   企业微信:   smtp.exmail.qq.com:465
