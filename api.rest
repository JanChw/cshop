### ============================
### 变量
### ============================

@baseUrl = http://localhost:3000/api/v1
@token = Bearer {{accessToken}}
@adminToken = Bearer {{adminAccessToken}}

### ============================
### 健康
### ============================

GET {{baseUrl}}/health
# 健康检查

### ============================
### 认证
### ============================

POST {{baseUrl}}/auth/register
Content-Type: application/json
# 用户注册，返回 accessToken + refreshToken + 用户信息
{
  "email": "user@example.com",
  "password": "password123",
  "name": "张三"
}

### 登录
POST {{baseUrl}}/auth/login
Content-Type: application/json
# 用户登录，返回令牌 + 员工上下文（isStaff/roleId/permissions）
{
  "email": "user@example.com",
  "password": "password123"
}

### 刷新令牌
POST {{baseUrl}}/auth/refresh
Content-Type: application/json
# 交换 refreshToken 获取新的 accessToken + refreshToken（轮转）
{
  "refreshToken": "{{refreshToken}}"
}

### 登出当前会话
POST {{baseUrl}}/auth/logout
Content-Type: application/json
Authorization: {{token}}
# 撤销指定 refreshToken 对应的会话
{
  "refreshToken": "{{refreshToken}}"
}

### 登出所有会话
POST {{baseUrl}}/auth/logout-all
Authorization: {{token}}
# 撤销当前用户的所有活跃会话

### 获取当前用户信息
GET {{baseUrl}}/auth/me
Authorization: {{token}}
# 返回用户资料 + 员工上下文（isStaff/roleId/roleName/permissions）

### 修改密码
POST {{baseUrl}}/auth/change-password
Content-Type: application/json
Authorization: {{token}}
# 修改密码后撤销其他会话；X-Current-Refresh-Token 可保留当前会话
{
  "oldPassword": "password123",
  "newPassword": "newpassword456"
}

### 更新当前用户资料
PATCH {{baseUrl}}/auth/me
Content-Type: application/json
Authorization: {{token}}
# 至少传 name 或 email 其中一个
{
  "name": "新名字"
}

### 注销当前用户
DELETE {{baseUrl}}/auth/me
Authorization: {{token}}
# 有订单则软禁用，无订单则硬删除

### 获取会话列表
GET {{baseUrl}}/auth/sessions
Authorization: {{token}}
# 返回当前用户所有会话记录

### 撤销指定会话
DELETE {{baseUrl}}/auth/sessions/1
Authorization: {{token}}
# 按 session id 撤销

### 忘记密码
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json
# 限速 5次/分钟；始终返回成功（防止邮箱枚举）
{
  "email": "user@example.com"
}

