### ============================
### 管理面板
### ============================

GET {{baseUrl}}/admin/dashboard
Authorization: {{adminToken}}
# 权限: analytics.read
# 返回商品数、订单数、待处理数、总收入

### ============================
### 商品管理
### ============================

GET {{baseUrl}}/admin/products?page=1&limit=20&includeInactive=true
Authorization: {{adminToken}}
# 权限: product.read
# 含下架商品

### 获取商品详情
GET {{baseUrl}}/admin/products/1
Authorization: {{adminToken}}
# 权限: product.read，含规格

### 创建商品
POST {{baseUrl}}/admin/products
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: product.create
{
  "name": "T恤",
  "description": "纯棉T恤",
  "basePrice": 99.9,
  "categoryId": 1,
  "stock": 100,
  "isActive": true
}

### 更新商品
PUT {{baseUrl}}/admin/products/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: product.update
{
  "name": "新款T恤",
  "basePrice": 129.9
}

### 上传商品主图
POST {{baseUrl}}/admin/products/1/image
Authorization: {{adminToken}}
# 权限: product.update
# formData: file（jpg/png/webp），走 sharp 生成4变体，写入 uploads 表并更新 products.image

### 下架商品
DELETE {{baseUrl}}/admin/products/1
Authorization: {{adminToken}}
# 权限: product.delete（软删除，设 isActive=false）

### 恢复商品
POST {{baseUrl}}/admin/products/1/restore
Authorization: {{adminToken}}
# 权限: product.update（设 isActive=true）

### 获取商品规格列表
GET {{baseUrl}}/admin/products/1/variants
Authorization: {{adminToken}}
# 权限: product.read

### 创建商品规格
POST {{baseUrl}}/admin/products/1/variants
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: product.create; material（材质）和 weight（克重）可选
{
  "size": "L",
  "color": "黑色",
  "material": "纯棉",
  "weight": 200,
  "priceAdjustment": 10,
  "stock": 50
}

### 更新商品规格
PUT {{baseUrl}}/admin/products/1/variants/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: product.update
{
  "size": "XL",
  "stock": 30
}

### 删除商品规格
DELETE {{baseUrl}}/admin/products/1/variants/1
Authorization: {{adminToken}}
# 权限: product.delete（有订单/购物车/设计引用时拒绝）

### ============================
### 订单管理
### ============================

GET {{baseUrl}}/admin/orders?page=1&limit=20&status=pending
Authorization: {{adminToken}}
# 权限: order.read

### 获取订单详情
GET {{baseUrl}}/admin/orders/1
Authorization: {{adminToken}}
# 权限: order.read，含明细 + 用户信息

### 更新订单状态
PUT {{baseUrl}}/admin/orders/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: order.update_status
# 状态机校验：pending→paid→processing→shipped→completed；任意非终态→cancelled
# 自动设置 paidAt/shippedAt/completedAt/cancelledAt 时间戳
# cancelled 时回退库存
{
  "status": "shipped",
  "trackingNo": "SF1234567890"
}

### ============================
### 贴纸管理
### ============================

### 上传贴纸
POST {{baseUrl}}/admin/stickers
Authorization: {{adminToken}}
# 权限: sticker.create
# formData: file（png/webp）、name、category（默认 general）

### 更新贴纸
PUT {{baseUrl}}/admin/stickers/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: sticker.update，至少传 name 或 category
{
  "name": "爱心",
  "category": "emoji"
}

### 删除贴纸
DELETE {{baseUrl}}/admin/stickers/1
Authorization: {{adminToken}}
# 权限: sticker.delete，同时删除文件

### ============================
### 分类管理
### ============================

### 创建分类
POST {{baseUrl}}/admin/categories
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: category.create，slug 需唯一
{
  "name": "T恤",
  "slug": "tshirt"
}

### 更新分类
PUT {{baseUrl}}/admin/categories/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: category.update
{
  "name": "短袖T恤",
  "slug": "short-sleeve-tshirt"
}

### 删除分类
DELETE {{baseUrl}}/admin/categories/1
Authorization: {{adminToken}}
# 权限: category.delete（有商品引用时拒绝）

### ============================
### 员工管理
### ============================

GET {{baseUrl}}/admin/staff?page=1&limit=20
Authorization: {{adminToken}}
# 权限: staff.read，关联用户+角色信息

### 创建员工
POST {{baseUrl}}/admin/staff
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: staff.create，同时创建 user + staff 记录
{
  "email": "staff@example.com",
  "password": "password123",
  "name": "店员A",
  "roleId": 2,
  "employeeNo": "E001",
  "department": "运营",
  "position": "客服"
}

### 更新员工
PUT {{baseUrl}}/admin/staff/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: staff.update，不能停用自己
{
  "roleId": 3,
  "status": "active"
}

### 删除员工
DELETE {{baseUrl}}/admin/staff/1
Authorization: {{adminToken}}
# 权限: staff.delete，软删除（标记 resigned），不能删自己

### ============================
### 角色管理
### ============================

GET {{baseUrl}}/admin/roles
Authorization: {{adminToken}}
# 权限: staff.read，含每个角色的权限列表

### 获取所有权限码
GET {{baseUrl}}/admin/roles/permissions
Authorization: {{adminToken}}
# 权限: staff.read，按模块分组

### 创建角色
POST {{baseUrl}}/admin/roles
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: staff.create，name 只允许小写字母/数字/下划线
{
  "name": "content_editor",
  "displayName": "内容编辑",
  "description": "管理商品和贴纸内容"
}

### 删除角色
DELETE {{baseUrl}}/admin/roles/5
Authorization: {{adminToken}}
# 权限: staff.create，系统角色不可删，有员工引用时拒绝

### 更新角色权限
PUT {{baseUrl}}/admin/roles/5/permissions
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: staff.create，系统角色不可修改，整体替换权限列表
{
  "permissionIds": [1, 2, 3, 5, 8]
}

### ============================
### 用户管理
### ============================

GET {{baseUrl}}/admin/users?page=1&limit=20&q=张&role=customer&disabled=false
Authorization: {{adminToken}}
# 权限: user.read，支持搜索+角色+禁用状态筛选

### 获取用户详情
GET {{baseUrl}}/admin/users/1
Authorization: {{adminToken}}
# 权限: user.read，含订单数

### 更新用户
PUT {{baseUrl}}/admin/users/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: user.update，不能禁用自己
{
  "name": "新名字",
  "disabled": false
}

### 删除/禁用用户
DELETE {{baseUrl}}/admin/users/1
Authorization: {{adminToken}}
# 权限: user.disable，有订单则软禁用，无则硬删除，不能删自己

### 重置用户密码
POST {{baseUrl}}/admin/users/1/reset-password
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: user.disable，重置后撤销该用户所有会话
{
  "newPassword": "newpassword456"
}

### ============================
### 数据分析
### ============================

### 在线用户
GET {{baseUrl}}/admin/analytics/online
Authorization: {{adminToken}}
# 权限: analytics.read，5分钟内活跃用户+地理位置

### 活动事件
GET {{baseUrl}}/admin/analytics/events?page=1&limit=20&type=login&from=2025-01-01&to=2025-12-31&deviceType=mobile&country=CN
Authorization: {{adminToken}}
# 权限: analytics.read

### 分析汇总
GET {{baseUrl}}/admin/analytics/summary?period=7d
Authorization: {{adminToken}}
# 权限: analytics.read
# period: today / 7d / 30d
# 返回: DAU/PV/热门商品/转化漏斗(view→cart→order)/设备分布/PV趋势

### 地理分布
GET {{baseUrl}}/admin/analytics/geo?from=2025-01-01&to=2025-12-31
Authorization: {{adminToken}}
# 权限: analytics.read，按国家/地区/城市分布

### 审计日志
GET {{baseUrl}}/admin/analytics/audit?page=1&limit=20&from=2025-01-01&to=2025-12-31
Authorization: {{adminToken}}
# 权限: analytics.read，管理员操作记录，含用户名

### 留存率
GET {{baseUrl}}/admin/analytics/retention?cohortDate=2025-06-01
Authorization: {{adminToken}}
# 权限: analytics.read，7天留存分析

### 导出分析数据
GET {{baseUrl}}/admin/analytics/export?from=2025-01-01&to=2025-12-31&eventType=order_create
Authorization: {{adminToken}}
# 权限: analytics.export，返回 CSV 文件下载

### ============================
### 系统设置
### ============================

GET {{baseUrl}}/admin/settings
Authorization: {{adminToken}}
# 权限: settings.read，返回 key-value 映射

### 更新设置
PUT {{baseUrl}}/admin/settings
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: settings.update
{
  "activity_retention_days": "30"
}

### ============================
### 备份管理
### ============================

### 创建备份
POST {{baseUrl}}/admin/backup
Authorization: {{adminToken}}
# 权限: backup.create，SQLite VACUUM INTO

### 获取备份列表
GET {{baseUrl}}/admin/backup
Authorization: {{adminToken}}
# 权限: backup.create

### 下载备份
GET {{baseUrl}}/admin/backup/1/download
Authorization: {{adminToken}}
# 权限: backup.download，返回 .db 文件

### 从备份恢复
POST {{baseUrl}}/admin/backup/1/restore?confirm=yes
Authorization: {{adminToken}}
# 权限: backup.create，必须带 confirm=yes；先备份当前库再覆盖

### 删除备份
DELETE {{baseUrl}}/admin/backup/1
Authorization: {{adminToken}}
# 权限: backup.delete

### ============================
### 菜单管理
### ============================

GET {{baseUrl}}/admin/menus?type=admin
Authorization: {{adminToken}}
# 权限: menu.read，返回树形结构，type 可选 admin(后台)/nav(前台)

### 创建菜单
POST {{baseUrl}}/admin/menus
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: menu.create
{
  "parentId": null,
  "name": "商品管理",
  "path": "/products",
  "icon": "shopping-bag",
  "sort": 100,
  "type": "admin"
}

### 更新菜单
PUT {{baseUrl}}/admin/menus/1
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: menu.update
{
  "name": "商品列表",
  "sort": 50
}

### 删除菜单
DELETE {{baseUrl}}/admin/menus/1
Authorization: {{adminToken}}
# 权限: menu.delete，级联删除子菜单

### 批量排序
PUT {{baseUrl}}/admin/menus/reorder
Content-Type: application/json
Authorization: {{adminToken}}
# 权限: menu.update，拖拽排序后批量更新 parentId + sort
[
  {"id": 1, "parentId": null, "sort": 100},
  {"id": 2, "parentId": 1, "sort": 200},
  {"id": 3, "parentId": 1, "sort": 300}
]

