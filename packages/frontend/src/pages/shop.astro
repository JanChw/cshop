---

<MainLayout title="商店">
<!-- Shop page overrides for cool palette -->
<style>
:root {
  --color-background: #f9f9ff;
  --color-on-background: #151c27;
  --color-surface: #f9f9ff;
  --color-on-surface: #151c27;
  --color-surface-variant: #dce2f3;
  --color-on-surface-variant: #434656;
  --color-surface-container: #e7eefe;
  --color-surface-container-low: #f0f3ff;
  --color-surface-container-high: #e2e8f8;
  --color-surface-container-highest: #dce2f3;
  --color-secondary: #5c5f61;
  --color-secondary-container: #e0e3e5;
  --color-outline: #737688;
  --color-outline-variant: #c3c5d9;
  --color-primary: #c2652a;
  --color-on-primary: #ffffff;
  --color-primary-container: #c2652a;
  --color-on-primary-container: #ffffff;
}
</style>

<!-- TopAppBar -->
<header class="bg-surface border-b border-outline-variant sticky top-0 z-50">
<div class="flex justify-between items-center px-container-margin h-12 w-full">
<div class="flex items-center gap-4">
<button class="material-symbols-outlined text-primary hover:opacity-80 transition-opacity active:scale-95 duration-150">menu</button>
<span class="text-title-md font-bold text-primary">ByChooow</span>
</div>
<div class="flex items-center gap-4">
<button onclick="window.location.href='/search'" class="material-symbols-outlined text-on-surface-variant hover:opacity-80 transition-opacity">search</button>
<div class="w-8 h-8 rounded-full bg-secondary-container overflow-hidden border border-outline-variant">
<img alt="User Profile" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuACO1FDt1_uQh0Ln4IggOJsy5ok06DnWLxkv-5QqU_NHrM2pT6ekUGzJiEMa_8Bc-a5x8UExX9Pa1IKJ0AdUWXxcdUk3JcFUf2AJ4fH81hhmfB-dcUNFhgjYOPUN5w4Kpn_r8xmCVsdhG5a5A_cvCMl8NQh0N6OY7KYtMd_dTgKldopmOGbd0Pv1qUGdIzpci5rxf9-qsILxfX_27XLvCczAnNF4Pc6I4nEeZZn1ds9Y8AjTxaS2MrfrRBe1T4YPK8LFSkGbZEuDcU"/>
</div>
</div>
</div>
</header>

<ShopContent products={products} client:load />

<!-- Floating Action Button -->
<button class="fixed right-6 bottom-24 w-14 h-14 bg-primary text-on-primary rounded-lg shadow-lg flex items-center justify-center active:scale-95 transition-transform">
<span class="material-symbols-outlined">shopping_cart</span>
</button>

<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full bg-surface border-t border-outline-variant z-50 flex justify-around items-center px-4 pb-4 pt-2">
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/"><span class="material-symbols-outlined">home</span><span class="text-label-md mt-1">首页</span></a>
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/design"><span class="material-symbols-outlined">brush</span><span class="text-label-md mt-1">设计</span></a>
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/cart"><span class="material-symbols-outlined">shopping_cart</span><span class="text-label-md mt-1">购物车</span></a>
<a class="flex flex-col items-center justify-center bg-primary-container text-on-primary-container rounded-lg px-4 py-1 scale-90 transition-transform duration-200" href="/shop"><span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">storefront</span><span class="text-label-md mt-1">商店</span></a>
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/person"><span class="material-symbols-outlined">person</span><span class="text-label-md mt-1">个人中心</span></a>
</nav>
</MainLayout>
