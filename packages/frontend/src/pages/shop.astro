<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full bg-surface border-t border-outline-variant z-50 flex justify-around items-center px-4 pb-4 pt-2">
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/">
<span class="material-symbols-outlined">home</span>
<span class="text-label-md mt-1">首页</span>
</a>
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/design">
<span class="material-symbols-outlined">brush</span>
<span class="text-label-md mt-1">设计</span>
</a>
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/cart">
<span class="material-symbols-outlined">shopping_cart</span>
<span class="text-label-md mt-1">购物车</span>
</a>
<a class="flex flex-col items-center justify-center bg-primary-container text-on-primary-container rounded-lg px-4 py-1 scale-90 transition-transform duration-200" href="/shop">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">storefront</span>
<span class="text-label-md mt-1">商店</span>
</a>
<a class="flex flex-col items-center justify-center text-secondary px-4 py-1 hover:bg-surface-variant rounded-lg transition-opacity" href="/person">
<span class="material-symbols-outlined">person</span>
<span class="text-label-md mt-1">个人中心</span>
</a>
</nav>

<!-- Floating Action Button -->
<button class="fixed right-6 bottom-24 w-14 h-14 bg-primary text-on-primary rounded-lg shadow-lg flex items-center justify-center active:scale-95 transition-transform">
<span class="material-symbols-outlined">shopping_cart</span>
</button>

<script>
document.querySelectorAll('.group').forEach(card => {
    card.addEventListener('click', () => {
        card.style.transform = 'scale(0.98)';
        setTimeout(() => card.style.transform = 'scale(1)', 100);
    });
});

const scrollContainer = document.querySelector('.no-scrollbar');
if (scrollContainer) {
    scrollContainer.addEventListener('wheel', (evt) => {
        evt.preventDefault();
        scrollContainer.scrollLeft += evt.deltaY;
    });
}
</script>

<style>
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

/* Shop page overrides for cool palette */
:root {
  --color-background: #f9f9ff;
  --color-on-background: #151c27;
  --color-surface: #f9f9ff;
  --color-on-surface: #151c27;
  --color-surface-variant: #dce2f3;
  --color-on-surface-variant: #434656;
  --color-surface-container: #e7eefe;
  --color-surface-container-low: #f0f3ff;
  --color-surface-container-high: #e2e8f8;
  --color-surface-container-highest: #dce2f3;
  --color-secondary: #5c5f61;
  --color-secondary-container: #e0e3e5;
  --color-outline: #737688;
  --color-outline-variant: #c3c5d9;
  --color-primary: #c2652a;
  --color-on-primary: #ffffff;
  --color-primary-container: #c2652a;
  --color-on-primary-container: #ffffff;
}
</style>
